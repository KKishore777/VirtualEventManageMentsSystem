@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int eventCount = ViewBag.EventCount ?? 0;
    int speakerCount = ViewBag.SpeakerCount ?? 0;
}

<style>
    :root {
        --admin-primary: #2563eb;
        --admin-secondary: #64748b;
        --glass: rgba(255, 255, 255, 0.95);
    }

    body {
        background-color: #f8fafc;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .hero-section {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        color: white;
        padding: 3rem 0;
        border-radius: 0 0 2rem 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .stat-card {
        background: white;
        border: none;
        border-radius: 1rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

    .action-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        display: inline-block;
        padding: 1rem;
        border-radius: 1rem;
        background: #f1f5f9;
        transition: 0.3s;
    }

    .action-link:hover .action-icon {
        background: var(--admin-primary);
        color: white !important;
    }

    .action-card {
        border: 1px solid #e2e8f0;
        border-radius: 1.25rem;
        height: 100%;
        transition: 0.3s;
    }

        .action-card:hover {
            border-color: var(--admin-primary);
            background: #f0f7ff;
        }
</style>

<div class="hero-section">
    <div class="container text-center">
        <h1 class="display-5 fw-bold mb-2">Admin Dashboard</h1>
        <p class="fs-5 opacity-75">Logged in as: <span class="fw-bold">@Context.Session.GetString("UserEmail")</span></p>
        <div class="mt-3">
            <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-shield-check me-1"></i> System Secure</span>
        </div>
    </div>
</div>

<div class="container">
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card stat-card shadow-sm p-4">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 bg-primary bg-opacity-10 p-3 rounded-3 text-primary">
                        <i class="bi bi-calendar-event fs-2"></i>
                    </div>
                    <div class="flex-grow-1 ms-4">
                        <h6 class="text-muted text-uppercase fw-bold mb-1 small">Total Events</h6>
                        <h2 class="mb-0 fw-bold">@eventCount</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card stat-card shadow-sm p-4">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 bg-warning bg-opacity-10 p-3 rounded-3 text-warning">
                        <i class="bi bi-mic fs-2"></i>
                    </div>
                    <div class="flex-grow-1 ms-4">
                        <h6 class="text-muted text-uppercase fw-bold mb-1 small">Total Speakers</h6>
                        <h2 class="mb-0 fw-bold">@speakerCount</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12 mb-4">
            <h4 class="fw-bold"><i class="bi bi-command me-2 text-primary"></i>Management Hub</h4>
        </div>

        <div class="col-md-4">
            <a asp-action="EventList" class="text-decoration-none action-link">
                <div class="card action-card p-4 text-center">
                    <div class="action-icon text-primary"><i class="bi bi-calendar3"></i></div>
                    <h5 class="text-dark fw-bold">Manage Events</h5>
                    <p class="text-muted small">Create, update, and delete event records</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="SessionList" class="text-decoration-none action-link">
                <div class="card action-card p-4 text-center">
                    <div class="action-icon text-success"><i class="bi bi-clock-history"></i></div>
                    <h5 class="text-dark fw-bold">Manage Sessions</h5>
                    <p class="text-muted small">Configure categories and timings within events</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="SpeakerList" class="text-decoration-none action-link">
                <div class="card action-card p-4 text-center">
                    <div class="action-icon text-warning"><i class="bi bi-person-badge"></i></div>
                    <h5 class="text-dark fw-bold">Manage Speakers</h5>
                    <p class="text-muted small">Add/Remove speakers and assign to sessions</p>
                </div>
            </a>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">