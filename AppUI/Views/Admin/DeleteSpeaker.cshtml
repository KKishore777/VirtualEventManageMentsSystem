@model DAL.Models.SpeakersDetails

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Delete Event</h2>

<h4>Are you sure you want to delete this Session?</h4>

<div class="alert alert-danger">
    <p><strong>Name:</strong> @Model.SpeakerName</p>
    <p><strong>ID:</strong> @Model.SpeakerId</p>
</div>

<form method="post">
   

    <button class="btn btn-danger">Delete</button>
    <a asp-action="SessionList" class="btn btn-secondary">Cancel</a>
</form>